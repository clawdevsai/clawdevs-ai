{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEO Input Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "delegar_po",
        "consultar",
        "autorizar",
        "alertar"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "diretor",
        "po",
        "arquiteto",
        "sistema"
      ]
    },
    "auth_token": {
      "type": "string",
      "minLength": 6
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brief_id": {
          "type": "string",
          "pattern": "^BRIEF-\\d+(?:-[a-z0-9-]+)?$"
        },
        "cost_estimate": {
          "type": "number",
          "minimum": 0
        },
        "data_classification": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "nao"
          ]
        }
      },
      "required": [
        "brief_id"
      ]
    }
  },
  "required": [
    "intent",
    "source"
  ]
}
