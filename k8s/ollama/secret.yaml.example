# Ollama Cloud — para usar modelos como glm-5:cloud.
# Copie para secret.yaml e preencha com sua chave: cp secret.yaml.example secret.yaml
# Não commitar secret.yaml (está no .gitignore).
apiVersion: v1
kind: Secret
metadata:
  name: ollama-cloud
  namespace: ai-agents
type: Opaque
stringData:
  OLLAMA_API_KEY: "SUA_CHAVE_OLLAMA_CLOUD"
