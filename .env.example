# ClawDevs — exemplo de variáveis de ambiente
# Copie para .env e preencha: cp .env.example .env
# Nunca commitar .env com valores reais.

# --- Telegram (interface Diretor ↔ CEO; só o CEO usa) ---
# Bot token: criar em https://t.me/BotFather com /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Slack (todos os agentes podem conversar; discussões entre agentes usam Ollama local GPU) ---
# App Token (xapp-...) e Bot Token (xoxb-...): criar app em https://api.slack.com/apps, workspace clawdevsai, Socket Mode.
# Ver: https://docs.openclaw.ai/channels/slack
SLACK_ENABLED=true
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
# Opcional: ID do Diretor no Slack (ex.: U01234ABCD) para allowFrom em DMs. Se vazio, usar pairing: openclaw pairing approve slack <CODE>
SLACK_DIRECTOR_USER_ID=

# --- Ollama (quando rodar OpenClaw fora do cluster) ---
OLLAMA_HOST=http://127.0.0.1:11434

# --- Opcional: Google Gemini (CEO em nuvem em fases futuras) ---
# GOOGLE_AI_KEY=
