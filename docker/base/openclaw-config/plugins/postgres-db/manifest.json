{
  "id": "postgres-db",
  "name": "PostgreSQL Database Plugin",
  "version": "1.0.0",
  "description": "Persistent storage for sessions, memories, artifacts, and operational data",
  "author": "ClawDevs AI",
  "license": "MIT",
  "loadOrder": 500,
  "entry": "src/index.ts",
  "permissions": ["database_read", "database_write", "environment_variables"],
  "hooks": [
    {
      "event": "session.saved",
      "handler": "persistSessionToDatabase",
      "timeout_ms": 5000,
      "critical": true,
      "description": "Persist session to database after agent run"
    },
    {
      "event": "error.occurred",
      "handler": "logErrorToDB",
      "timeout_ms": 2000,
      "critical": false,
      "description": "Log errors with full context for debugging"
    }
  ],
  "tools": [
    {
      "name": "query_database",
      "description": "Execute SELECT query against database",
      "schema": {
        "type": "object",
        "properties": {
          "sql": {
            "type": "string",
            "description": "SQL SELECT query"
          },
          "params": {
            "type": "array",
            "description": "Query parameters (for parameterized queries)"
          },
          "timeout_ms": {
            "type": "integer",
            "default": 10000
          }
        },
        "required": ["sql"]
      }
    },
    {
      "name": "save_record",
      "description": "Insert or update a record",
      "schema": {
        "type": "object",
        "properties": {
          "table": {
            "type": "string",
            "description": "Table name"
          },
          "record": {
            "type": "object",
            "description": "Record data (key-value pairs)"
          },
          "upsert": {
            "type": "boolean",
            "default": true,
            "description": "Update if exists, insert if not"
          }
        },
        "required": ["table", "record"]
      }
    },
    {
      "name": "transaction_begin",
      "description": "Start a database transaction"
    },
    {
      "name": "transaction_commit",
      "description": "Commit transaction"
    },
    {
      "name": "transaction_rollback",
      "description": "Rollback transaction"
    }
  ],
  "config": {
    "properties": {
      "host": {
        "type": "string",
        "description": "PostgreSQL host",
        "default": "postgres"
      },
      "port": {
        "type": "integer",
        "default": 5432
      },
      "database": {
        "type": "string",
        "default": "openclaw"
      },
      "user": {
        "type": "string",
        "description": "Database user",
        "required": true,
        "default": "openclaw_user"
      },
      "password": {
        "type": "string",
        "description": "Database password",
        "required": true,
        "sensitive": true,
        "default": "${PANEL_DB_PASSWORD}"
      },
      "ssl": {
        "type": "boolean",
        "default": false
      },
      "pool_size": {
        "type": "integer",
        "default": 20,
        "description": "Connection pool size"
      },
      "query_timeout_ms": {
        "type": "integer",
        "default": 10000
      }
    },
    "required": ["user", "password"]
  },
  "monitoring": {
    "metrics": [
      "queries_total",
      "queries_failed",
      "average_query_time_ms",
      "connection_pool_usage",
      "transactions_active"
    ],
    "alerts": [
      {
        "name": "query_timeout",
        "condition": "query_time_ms > timeout_ms",
        "severity": "warning"
      },
      {
        "name": "connection_pool_exhausted",
        "condition": "active_connections >= pool_size",
        "severity": "critical"
      }
    ]
  }
}
