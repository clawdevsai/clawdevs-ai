{
  "id": "openrouter-llm",
  "name": "OpenRouter Remote LLM Plugin",
  "version": "1.0.0",
  "description": "Remote LLM inference for complex reasoning (Claude, GPT-4)",
  "author": "ClawDevs AI",
  "license": "MIT",
  "loadOrder": 300,
  "entry": "src/index.ts",
  "permissions": ["network_access", "external_api_calls", "environment_variables"],
  "hooks": [
    {
      "event": "before.model",
      "handler": "validateRemoteConfig",
      "timeout_ms": 500,
      "critical": true,
      "description": "Verify API key and route decision"
    },
    {
      "event": "model.response",
      "handler": "trackCosts",
      "timeout_ms": 1000,
      "critical": false,
      "description": "Track token usage and costs"
    }
  ],
  "tools": [
    {
      "name": "openrouter_chat",
      "description": "Multi-turn chat with remote LLM",
      "schema": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "role": {
                  "type": "string",
                  "enum": ["system", "user", "assistant"]
                },
                "content": {
                  "type": "string"
                }
              }
            },
            "description": "Conversation messages"
          },
          "model": {
            "type": "string",
            "description": "Model to use (defaults to configured)",
            "default": "${OPENROUTER_MODEL}"
          },
          "temperature": {
            "type": "number",
            "default": 0.7
          },
          "max_tokens": {
            "type": "integer",
            "default": 4096
          },
          "top_p": {
            "type": "number",
            "default": 1.0
          }
        },
        "required": ["messages"]
      }
    }
  ],
  "config": {
    "properties": {
      "api_key": {
        "type": "string",
        "description": "OpenRouter API key",
        "required": true,
        "sensitive": true,
        "default": "${OPENROUTER_API_KEY}"
      },
      "base_url": {
        "type": "string",
        "description": "OpenRouter API endpoint",
        "default": "${OPENROUTER_BASE_URL}"
      },
      "model": {
        "type": "string",
        "description": "Default model",
        "default": "${OPENROUTER_MODEL}"
      },
      "timeout_ms": {
        "type": "integer",
        "default": 120000
      },
      "max_tokens": {
        "type": "integer",
        "default": 4096
      },
      "cost_tracking": {
        "type": "boolean",
        "description": "Track tokens and costs",
        "default": true
      },
      "retry_attempts": {
        "type": "integer",
        "default": 3
      }
    },
    "required": ["api_key", "model"]
  },
  "monitoring": {
    "metrics": [
      "total_tokens_used",
      "total_cost",
      "average_latency_ms",
      "error_rate",
      "api_calls_total"
    ],
    "alerts": [
      {
        "name": "cost_overrun",
        "condition": "monthly_cost > budget_limit",
        "severity": "critical"
      },
      {
        "name": "api_error_rate_high",
        "condition": "error_rate > 5%",
        "severity": "warning"
      }
    ]
  }
}
