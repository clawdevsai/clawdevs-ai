{
  "id": "redis-cache",
  "name": "Redis Cache Plugin",
  "version": "1.0.0",
  "description": "Fast caching layer for frequently accessed data",
  "author": "ClawDevs AI",
  "license": "MIT",
  "loadOrder": 600,
  "entry": "src/index.ts",
  "permissions": ["cache_read", "cache_write", "environment_variables"],
  "hooks": [
    {
      "event": "context.loaded",
      "handler": "loadMemoriesFromCache",
      "timeout_ms": 1000,
      "critical": false,
      "description": "Load frequently accessed memories from cache"
    },
    {
      "event": "tool.executed",
      "handler": "cacheToolResults",
      "timeout_ms": 500,
      "critical": false,
      "description": "Cache tool results for reuse"
    },
    {
      "event": "session.saved",
      "handler": "updateSessionCache",
      "timeout_ms": 1000,
      "critical": false,
      "description": "Update session metadata in cache"
    }
  ],
  "tools": [
    {
      "name": "cache_get",
      "description": "Retrieve value from cache",
      "schema": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Cache key"
          }
        },
        "required": ["key"]
      }
    },
    {
      "name": "cache_set",
      "description": "Store value in cache",
      "schema": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string",
            "description": "Value to cache (JSON serializable)"
          },
          "ttl_seconds": {
            "type": "integer",
            "description": "Time to live",
            "default": 3600
          }
        },
        "required": ["key", "value"]
      }
    },
    {
      "name": "cache_delete",
      "description": "Remove value from cache",
      "schema": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          }
        },
        "required": ["key"]
      }
    },
    {
      "name": "cache_clear_pattern",
      "description": "Clear all keys matching pattern",
      "schema": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string",
            "description": "Redis pattern (e.g., 'memory:*')"
          }
        },
        "required": ["pattern"]
      }
    }
  ],
  "config": {
    "properties": {
      "host": {
        "type": "string",
        "default": "redis"
      },
      "port": {
        "type": "integer",
        "default": 6379
      },
      "password": {
        "type": "string",
        "description": "Redis password (if required)",
        "sensitive": true,
        "default": "${PANEL_REDIS_PASSWORD}"
      },
      "db": {
        "type": "integer",
        "default": 0
      },
      "default_ttl_seconds": {
        "type": "integer",
        "default": 3600,
        "description": "Default TTL for cached items"
      },
      "max_memory_mb": {
        "type": "integer",
        "default": 256,
        "description": "Maximum cache memory"
      },
      "eviction_policy": {
        "type": "string",
        "enum": ["lru", "lfu", "ttl"],
        "default": "lru",
        "description": "Eviction policy when max memory reached"
      }
    }
  },
  "monitoring": {
    "metrics": [
      "cache_hits",
      "cache_misses",
      "cache_hit_ratio",
      "cache_memory_used_mb",
      "evictions_total"
    ],
    "alerts": [
      {
        "name": "cache_hit_ratio_low",
        "condition": "hit_ratio < 0.5",
        "severity": "warning"
      },
      {
        "name": "cache_memory_near_limit",
        "condition": "memory_used > max_memory * 0.9",
        "severity": "warning"
      }
    ]
  }
}
