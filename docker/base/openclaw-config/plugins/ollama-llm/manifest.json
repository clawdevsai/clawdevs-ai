{
  "id": "ollama-llm",
  "name": "Ollama Local LLM Plugin",
  "version": "1.0.0",
  "description": "Local LLM inference via Ollama for cost optimization",
  "author": "ClawDevs AI",
  "license": "MIT",
  "loadOrder": 300,
  "entry": "src/index.ts",
  "permissions": ["network_access", "local_inference", "environment_variables"],
  "hooks": [
    {
      "event": "before.model",
      "handler": "routeToLocalModel",
      "timeout_ms": 500,
      "critical": false,
      "description": "Route simple/templated tasks to Ollama instead of remote LLM"
    },
    {
      "event": "model.response",
      "handler": "validateLocalOutput",
      "timeout_ms": 1000,
      "critical": false,
      "description": "Validate Ollama output quality"
    }
  ],
  "tools": [
    {
      "name": "ollama_embed",
      "description": "Generate embeddings for semantic search and memory ranking",
      "schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Text to embed"
          },
          "model": {
            "type": "string",
            "default": "nomic-embed-text"
          }
        },
        "required": ["text"]
      }
    },
    {
      "name": "ollama_complete",
      "description": "Simple text completion using local model",
      "schema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Prompt text"
          },
          "max_tokens": {
            "type": "integer",
            "default": 500
          },
          "temperature": {
            "type": "number",
            "default": 0.7,
            "minimum": 0,
            "maximum": 2
          }
        },
        "required": ["prompt"]
      }
    }
  ],
  "config": {
    "properties": {
      "base_url": {
        "type": "string",
        "description": "Ollama server URL",
        "default": "http://ollama:11434"
      },
      "embedding_model": {
        "type": "string",
        "description": "Model for embeddings",
        "default": "nomic-embed-text"
      },
      "completion_model": {
        "type": "string",
        "description": "Model for text completion (fallback)",
        "default": "mistral"
      },
      "timeout_ms": {
        "type": "integer",
        "default": 60000
      },
      "fallback_to_remote": {
        "type": "boolean",
        "description": "Fall back to remote LLM if local fails",
        "default": true
      }
    }
  },
  "monitoring": {
    "metrics": ["embeddings_generated", "completions_generated", "inference_latency_ms"],
    "alerts": []
  }
}
