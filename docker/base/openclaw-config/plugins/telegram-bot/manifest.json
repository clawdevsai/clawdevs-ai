{
  "id": "telegram-bot",
  "name": "Telegram Bot Plugin",
  "version": "1.0.0",
  "description": "Send messages and notifications to Telegram",
  "author": "ClawDevs AI",
  "license": "MIT",
  "loadOrder": 200,
  "entry": "src/index.ts",
  "permissions": ["network_access", "external_api_calls", "environment_variables"],
  "hooks": [
    {
      "event": "response.ready",
      "handler": "sendResponseToTelegram",
      "timeout_ms": 5000,
      "critical": false,
      "description": "Send final response to CEO via Telegram"
    },
    {
      "event": "error.occurred",
      "handler": "alertDirector",
      "timeout_ms": 5000,
      "critical": false,
      "description": "Send error alerts to director on critical failures"
    },
    {
      "event": "cron.done",
      "handler": "notifyCronStatus",
      "timeout_ms": 2000,
      "critical": false,
      "description": "Notify director of cron job completion/failure"
    }
  ],
  "tools": [
    {
      "name": "send_telegram_message",
      "description": "Send a text message to Telegram chat",
      "schema": {
        "type": "object",
        "properties": {
          "chat_id": {
            "type": "string",
            "description": "Telegram chat ID (default: CEO chat)"
          },
          "message": {
            "type": "string",
            "description": "Message text (supports Markdown)",
            "minLength": 1,
            "maxLength": 4096
          },
          "parse_mode": {
            "type": "string",
            "enum": ["Markdown", "HTML", "plain"],
            "default": "Markdown"
          },
          "disable_notification": {
            "type": "boolean",
            "default": false
          }
        },
        "required": ["message"]
      }
    },
    {
      "name": "send_telegram_notification",
      "description": "Send a formatted notification with title and metadata",
      "schema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Notification title"
          },
          "message": {
            "type": "string",
            "description": "Notification message"
          },
          "level": {
            "type": "string",
            "enum": ["info", "warning", "error", "critical"],
            "default": "info"
          },
          "metadata": {
            "type": "object",
            "description": "Additional key-value pairs to display"
          }
        },
        "required": ["title", "message"]
      }
    },
    {
      "name": "get_telegram_chat_id",
      "description": "Get Telegram chat ID for a user or agent",
      "schema": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "User ID, agent name, or 'ceo' (default)"
          }
        }
      }
    }
  ],
  "config": {
    "properties": {
      "bot_token": {
        "type": "string",
        "description": "Telegram Bot token from BotFather",
        "required": true,
        "sensitive": true,
        "default": "${TELEGRAM_BOT_TOKEN_CEO}"
      },
      "chat_id": {
        "type": "string",
        "description": "Default chat ID (CEO)",
        "required": true,
        "default": "${TELEGRAM_CHAT_ID_CEO}"
      },
      "markdown_enabled": {
        "type": "boolean",
        "description": "Use Markdown formatting",
        "default": true
      },
      "timeout_ms": {
        "type": "integer",
        "description": "API request timeout",
        "default": 10000
      },
      "retry_attempts": {
        "type": "integer",
        "default": 2
      }
    },
    "required": ["bot_token", "chat_id"]
  },
  "monitoring": {
    "metrics": ["messages_sent", "messages_failed", "average_latency_ms"],
    "alerts": [
      {
        "name": "message_send_failed",
        "condition": "message_failed_count > 3",
        "severity": "warning"
      }
    ]
  }
}
