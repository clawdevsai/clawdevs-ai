{
  "id": "searxng-search",
  "name": "SearXNG Web Search Plugin",
  "version": "1.0.0",
  "description": "Web search for current information and research",
  "author": "ClawDevs AI",
  "license": "MIT",
  "loadOrder": 400,
  "entry": "src/index.ts",
  "permissions": ["network_access", "external_api_calls", "environment_variables"],
  "hooks": [
    {
      "event": "after_tool_call",
      "handler": "sanitizeSearchResults",
      "timeout_ms": 2000,
      "critical": false,
      "description": "Remove PII and sensitive info from search results"
    },
    {
      "event": "tool.selected",
      "handler": "enforceRateLimits",
      "timeout_ms": 100,
      "critical": true,
      "description": "Enforce rate limits (max 30 requests/minute)"
    }
  ],
  "tools": [
    {
      "name": "web_search",
      "description": "Search the web for information",
      "schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query",
            "minLength": 1
          },
          "limit": {
            "type": "integer",
            "default": 10,
            "maximum": 30,
            "description": "Number of results to return"
          },
          "language": {
            "type": "string",
            "default": "pt-BR",
            "description": "Language code"
          }
        },
        "required": ["query"]
      }
    },
    {
      "name": "get_url_content",
      "description": "Fetch and parse webpage content",
      "schema": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "URL to fetch"
          },
          "timeout_ms": {
            "type": "integer",
            "default": 30000
          }
        },
        "required": ["url"]
      }
    }
  ],
  "config": {
    "properties": {
      "base_url": {
        "type": "string",
        "description": "SearXNG proxy URL",
        "default": "${SEARXNG_BASE_URL}"
      },
      "timeout_ms": {
        "type": "integer",
        "default": 30000
      },
      "max_results": {
        "type": "integer",
        "default": 10,
        "maximum": 30
      },
      "rate_limit_per_minute": {
        "type": "integer",
        "default": 30,
        "description": "Max requests per minute"
      },
      "sanitize_results": {
        "type": "boolean",
        "description": "Remove PII from results",
        "default": true
      }
    }
  },
  "monitoring": {
    "metrics": ["searches_total", "rate_limit_remaining", "average_latency_ms"],
    "alerts": [
      {
        "name": "rate_limit_exceeded",
        "condition": "requests_per_minute > limit",
        "severity": "warning"
      }
    ]
  }
}
