{
  "id": "github-integration",
  "name": "GitHub Integration Plugin",
  "version": "1.0.0",
  "description": "Manage GitHub repositories, issues, pull requests, and code",
  "author": "ClawDevs AI",
  "license": "MIT",
  "keywords": ["github", "version-control", "ci-cd", "code-management"],
  "loadOrder": 100,
  "entry": "src/index.ts",
  "permissions": [
    "network_access",
    "external_api_calls",
    "environment_variables",
    "file_read"
  ],
  "dependencies": {
    "openclaw": ">= 2026.3.0"
  },
  "hooks": [
    {
      "event": "before_model_resolve",
      "handler": "validateGitHubToken",
      "timeout_ms": 500,
      "critical": false,
      "description": "Verify GitHub token is available and valid"
    },
    {
      "event": "after_tool_call",
      "handler": "logGitHubOperation",
      "timeout_ms": 1000,
      "critical": false,
      "description": "Log all GitHub API operations for audit trail"
    },
    {
      "event": "tool.selected",
      "handler": "enforceRateLimits",
      "timeout_ms": 100,
      "critical": true,
      "description": "Enforce GitHub API rate limits (60 req/hour free, 5000 authenticated)"
    }
  ],
  "tools": [
    {
      "name": "create_github_issue",
      "description": "Create a new issue in a GitHub repository",
      "schema": {
        "type": "object",
        "properties": {
          "repository": {
            "type": "string",
            "description": "Repository in format 'owner/repo' or just 'repo' (uses GIT_ORG)"
          },
          "title": {
            "type": "string",
            "description": "Issue title (required)",
            "minLength": 1,
            "maxLength": 255
          },
          "body": {
            "type": "string",
            "description": "Issue description in Markdown (optional)"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels to assign (e.g., 'bug', 'enhancement', 'back_end')"
          },
          "assignees": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "GitHub usernames to assign"
          }
        },
        "required": ["repository", "title"]
      }
    },
    {
      "name": "check_pr_status",
      "description": "Get the status of a pull request",
      "schema": {
        "type": "object",
        "properties": {
          "repository": {
            "type": "string",
            "description": "Repository in format 'owner/repo'"
          },
          "pr_number": {
            "type": "integer",
            "description": "Pull request number"
          }
        },
        "required": ["repository", "pr_number"]
      }
    },
    {
      "name": "merge_pr",
      "description": "Merge a pull request to target branch",
      "schema": {
        "type": "object",
        "properties": {
          "repository": {
            "type": "string",
            "description": "Repository in format 'owner/repo'"
          },
          "pr_number": {
            "type": "integer",
            "description": "Pull request number"
          },
          "merge_method": {
            "type": "string",
            "enum": ["squash", "rebase", "merge"],
            "default": "squash",
            "description": "How to merge the PR"
          },
          "delete_head_branch": {
            "type": "boolean",
            "default": true,
            "description": "Delete branch after merge"
          }
        },
        "required": ["repository", "pr_number"]
      }
    },
    {
      "name": "list_issues",
      "description": "List issues in a repository with optional filters",
      "schema": {
        "type": "object",
        "properties": {
          "repository": {
            "type": "string",
            "description": "Repository in format 'owner/repo'"
          },
          "state": {
            "type": "string",
            "enum": ["open", "closed", "all"],
            "default": "open"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Filter by labels (AND logic)"
          },
          "limit": {
            "type": "integer",
            "default": 10,
            "maximum": 100
          }
        },
        "required": ["repository"]
      }
    },
    {
      "name": "add_pr_comment",
      "description": "Add a comment to a pull request",
      "schema": {
        "type": "object",
        "properties": {
          "repository": {
            "type": "string"
          },
          "pr_number": {
            "type": "integer"
          },
          "body": {
            "type": "string",
            "description": "Comment text in Markdown",
            "minLength": 1
          }
        },
        "required": ["repository", "pr_number", "body"]
      }
    },
    {
      "name": "get_code_file",
      "description": "Read a file from a GitHub repository",
      "schema": {
        "type": "object",
        "properties": {
          "repository": {
            "type": "string"
          },
          "path": {
            "type": "string",
            "description": "File path relative to repo root"
          },
          "branch": {
            "type": "string",
            "default": "main",
            "description": "Branch to read from"
          }
        },
        "required": ["repository", "path"]
      }
    },
    {
      "name": "search_code",
      "description": "Search for code patterns across repositories",
      "schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query (supports GitHub syntax)"
          },
          "limit": {
            "type": "integer",
            "default": 10,
            "maximum": 30
          }
        },
        "required": ["query"]
      }
    }
  ],
  "config": {
    "properties": {
      "api_token": {
        "type": "string",
        "description": "GitHub Personal Access Token (read 'GIT_TOKEN' env var)",
        "required": true,
        "sensitive": true,
        "default": "${GIT_TOKEN}"
      },
      "organization": {
        "type": "string",
        "description": "Default GitHub organization (read 'GIT_ORG' env var)",
        "required": true,
        "default": "${GIT_ORG}"
      },
      "rate_limit": {
        "type": "integer",
        "description": "GitHub API rate limit per hour (5000 for authenticated)",
        "default": 5000
      },
      "retry_attempts": {
        "type": "integer",
        "description": "Number of retries on transient failures",
        "default": 3,
        "minimum": 1,
        "maximum": 5
      },
      "retry_backoff_ms": {
        "type": "integer",
        "description": "Exponential backoff multiplier (1s, 2s, 4s, 8s)",
        "default": 1000
      },
      "timeout_ms": {
        "type": "integer",
        "description": "API request timeout in milliseconds",
        "default": 30000
      },
      "log_all_operations": {
        "type": "boolean",
        "description": "Log all API calls for audit trail",
        "default": true
      }
    },
    "required": ["api_token", "organization"]
  },
  "monitoring": {
    "metrics": [
      "api_calls_total",
      "api_calls_failed",
      "rate_limit_remaining",
      "average_latency_ms",
      "cache_hit_ratio"
    ],
    "alerts": [
      {
        "name": "rate_limit_critical",
        "condition": "rate_limit_remaining < 100",
        "severity": "critical"
      },
      {
        "name": "api_error_rate_high",
        "condition": "error_rate > 10%",
        "severity": "warning"
      }
    ]
  },
  "healthCheck": {
    "enabled": true,
    "interval_seconds": 300,
    "checks": [
      {
        "name": "token_validity",
        "endpoint": "GET /user",
        "timeout_ms": 5000
      },
      {
        "name": "rate_limit_check",
        "endpoint": "GET /rate_limit",
        "timeout_ms": 5000
      },
      {
        "name": "org_access",
        "endpoint": "GET /orgs/{org}",
        "timeout_ms": 5000
      }
    ]
  }
}
