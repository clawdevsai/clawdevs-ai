{
  "name": "dev_frontend_implementation",
  "version": "2.0.0",
  "description": "Frontend architecture analysis, technology selection, and scalable UI patterns",
  "author": "clawdevs-ai",
  "license": "MIT",
  "skill_type": "implementation",
  "domain": "frontend_architecture",
  "hooks": {
    "before_execution": {
      "file": "src/hooks/before_execution.ts",
      "handler": "beforeExecutionHook",
      "description": "Analyze frontend requirements and generate architecture recommendations",
      "async": true
    },
    "after_execution": {
      "file": "src/hooks/after_execution.ts",
      "handler": "afterExecutionHook",
      "description": "Validate implementation against recommendations",
      "async": true
    }
  },
  "configuration": {
    "requirement_sources": {
      "type": "object",
      "properties": {
        "conversation": {
          "type": "boolean",
          "default": true,
          "description": "Parse requirements from conversation history"
        },
        "project_config": {
          "type": "boolean",
          "default": true,
          "description": "Parse requirements from project configuration"
        },
        "system_prompt": {
          "type": "boolean",
          "default": true,
          "description": "Parse requirements from system prompt"
        }
      }
    },
    "test_coverage_threshold": {
      "type": "number",
      "default": 0.8,
      "description": "Minimum test coverage percentage (0.0-1.0)"
    },
    "recommendation_confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "default": "high",
      "description": "Minimum confidence level for recommendations"
    },
    "include_alternatives": {
      "type": "boolean",
      "default": true,
      "description": "Include alternative architecture patterns in recommendations"
    }
  },
  "capabilities": {
    "requirement_analysis": {
      "description": "Parse and validate frontend requirements",
      "confidence": "high",
      "maturity": "production"
    },
    "pattern_matching": {
      "description": "Match requirements to optimal frontend patterns",
      "confidence": "high",
      "maturity": "production"
    },
    "architecture_recommendation": {
      "description": "Recommend frontend architecture, tech stack, and patterns",
      "confidence": "high",
      "maturity": "production"
    },
    "performance_optimization": {
      "description": "Recommend performance optimization strategies",
      "confidence": "high",
      "maturity": "production"
    },
    "pattern_validation": {
      "description": "Validate patterns follow design principles",
      "confidence": "high",
      "maturity": "production"
    }
  },
  "dependencies": {
    "zod": "^3.22.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "frontend",
    "architecture",
    "spa",
    "ssr",
    "micro-frontends",
    "components",
    "performance",
    "scalability",
    "typescript",
    "react",
    "vue",
    "nextjs",
    "vite"
  ],
  "patterns": {
    "component_driven": {
      "name": "Component-Driven Architecture",
      "languages": ["typescript", "javascript"],
      "frameworks": ["react", "vue", "angular"],
      "build_tools": ["vite", "webpack", "parcel"],
      "styling": ["css_modules", "tailwind", "styled_components"],
      "maturity": "production"
    },
    "progressive_enhancement": {
      "name": "Progressive Enhancement",
      "languages": ["typescript", "javascript"],
      "frameworks": ["nextjs", "nuxt", "remix"],
      "build_tools": ["webpack", "vite"],
      "styling": ["tailwind", "css_modules"],
      "maturity": "production"
    },
    "micro_frontend": {
      "name": "Micro-Frontend Architecture",
      "languages": ["typescript", "javascript"],
      "frameworks": ["react", "vue", "angular"],
      "build_tools": ["webpack", "module_federation"],
      "styling": ["css_modules", "design_tokens"],
      "maturity": "production"
    },
    "lightweight_spa": {
      "name": "Lightweight SPA",
      "languages": ["javascript", "typescript"],
      "frameworks": ["preact", "vanilla_js", "alpine"],
      "build_tools": ["vite", "esbuild"],
      "styling": ["tailwind", "vanilla_css"],
      "maturity": "production"
    },
    "headless_cms": {
      "name": "Headless CMS + Static Generation",
      "languages": ["javascript", "markdown"],
      "frameworks": ["11ty", "hugo", "astro"],
      "build_tools": ["webpack", "vite"],
      "styling": ["tailwind", "vanilla_css"],
      "maturity": "production"
    },
    "fullstack_monolith": {
      "name": "Full-Stack Monolith",
      "languages": ["javascript", "python", "ruby"],
      "frameworks": ["express", "django", "rails"],
      "build_tools": ["webpack", "esbuild"],
      "styling": ["bootstrap", "tailwind"],
      "maturity": "legacy"
    }
  }
}
